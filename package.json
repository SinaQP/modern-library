{
  "name": "personal-library-management-fa",
  "version": "1.0.0",
  "description": "سامانه مدیریت کتابخانه شخصی و ثبت امانت کتاب با Electron و SQLite",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "build": "npm run typecheck && npm run build:renderer",
    "build:renderer": "vite build",
    "check": "node --check main.js && node --check preload.js && node --check ipc/book-handlers.js && node --check database/db.js && node --check renderer/library-service.js && node --check renderer/app.js && node --check shared/errors.js && node --check shared/ipc/channels.js && npm run typecheck",
    "dev:renderer": "vite --host 127.0.0.1",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": [
    "electron",
    "sqlite",
    "persian",
    "rtl",
    "library-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.sina.modernlibrary",
    "productName": "Modern Library",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "renderer-dist/**/*",
      "ipc/**/*",
      "database/**/*",
      "shared/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
