{
  "name": "personal-library-management-fa",
  "version": "1.0.0",
  "description": "سامانه مدیریت کتابخانه شخصی و ثبت امانت کتاب با Electron و SQLite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check ipc/book-handlers.js && node --check database/db.js && node --check renderer/library-service.js && node --check renderer/app.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "electron",
    "sqlite",
    "persian",
    "rtl",
    "library-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sina.modernlibrary",
    "productName": "Modern Library",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "ipc/**/*",
      "database/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
